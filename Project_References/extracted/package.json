{
	"name": "monorepo",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently --kill-others --raw \"npm run dev --prefix apps/web\"",
		"build": "npm run build --prefix apps/web",
		"start": "node server.js",
		"lint": "concurrently --raw \"npm run lint --prefix apps/web\""
	},
	"dependencies": {
		"express": "^4.18.2"
	},
	"devDependencies": {
		"concurrently": "^9.1.2"
	},
	"workspaces": [
		"apps/*"
	]
}
