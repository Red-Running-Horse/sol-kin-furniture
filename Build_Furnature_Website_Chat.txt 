/**
 * Cloudinary Image Optimization Utilities
 * Handles all image transformations and URL generation
 */

const CLOUD_NAME = import.meta.env.VITE_CLOUDINARY_CLOUD_NAME;
const CLOUDINARY_URL = `https://res.cloudinary.com/${CLOUD_NAME}`;

/**
 * Generate optimized Cloudinary URL with transformations
 * @param {string} publicId - Image public ID (filename without extension)
 * @param {object} options - Transformation options
 * @returns {string} - Optimized Cloudinary URL
 */
export const generateCloudinaryUrl = (publicId, options = {}) => {
  const {
    width = 800,
    height = null,
    quality = 'auto',
    format = 'auto',
    crop = 'fill',
    gravity = 'auto',
    dpr = 'auto',
    fetch_format = 'auto',
    responsive = true,
  } = options;

  // Build transformation string
  let transforms = [];

  // Responsive sizing
  if (responsive && width) {
    transforms.push(`w_${width}`);
  }

  // Height (optional)
  if (height) {
    transforms.push(`h_${height}`);
  }

  // Crop mode
  if (crop) {
    transforms.push(`c_${crop}`);
  }

  // Gravity for smart cropping
  if (gravity) {
    transforms.push(`g_${gravity}`);
  }

  // Quality (auto detects optimal compression)
  transforms.push(`q_${quality}`);

  // Format (auto serves WebP to modern browsers, JPG to old ones)
  transforms.push(`f_${fetch_format}`);

  // Device pixel ratio for Retina displays
  if (dpr) {
    transforms.push(`dpr_${dpr}`);
  }

  const transformString = transforms.join(',');

  return `${CLOUDINARY_URL}/image/upload/${transformString}/sol-kin-furniture/${publicId}`;
};

/**
 * Generate responsive image sizes for srcset
 * @param {string} publicId - Image public ID
 * @returns {object} - Object with srcset and sizes strings
 */
export const generateResponsiveSrcset = (publicId) => {
  const sizes = [400, 600, 800, 1000, 1200, 1600];

  const srcset = sizes
    .map((size) => {
      const url = generateCloudinaryUrl(publicId, {
        width: size,
        quality: 'auto',
        format: 'auto',
      });
      return `${url} ${size}w`;
    })
    .join(', ');

  const sizes_attr = '(max-width: 600px) 100vw, (max-width: 1000px) 80vw, 1200px';

  return { srcset, sizes: sizes_attr };
};

/**
 * Generate thumbnail URL (small, optimized)
 * @param {string} publicId - Image public ID
 * @returns {string} - Thumbnail URL
 */
export const generateThumbnail = (publicId) => {
  return generateCloudinaryUrl(publicId, {
    width: 300,
    height: 300,
    crop: 'fill',
    quality: 'auto',
    format: 'auto',
  });
};

/**
 * Generate hero/full-width image URL
 * @param {string} publicId - Image public ID
 * @returns {string} - Full-width optimized URL
 */
export const generateHeroUrl = (publicId) => {
  return generateCloudinaryUrl(publicId, {
    width: 1600,
    height: 900,
    crop: 'fill',
    gravity: 'auto',
    quality: 'auto',
    format: 'auto',
  });
};

/**
 * Generate product gallery image URL
 * @param {string} publicId - Image public ID
 * @returns {string} - Product image URL
 */
export const generateProductUrl = (publicId) => {
  return generateCloudinaryUrl(publicId, {
    width: 1000,
    height: 800,
    crop: 'fill',
    gravity: 'auto',
    quality: 'auto',
    format: 'auto',
  });
};

/**
 * Generate multiple sizes for different use cases
 * @param {string} publicId - Image public ID
 * @returns {object} - Object with URLs for different sizes
 */
export const generateAllImageSizes = (publicId) => {
  return {
    thumbnail: generateThumbnail(publicId),
    small: generateCloudinaryUrl(publicId, { width: 500 }),
    medium: generateCloudinaryUrl(publicId, { width: 800 }),
    large: generateCloudinaryUrl(publicId, { width: 1200 }),
    hero: generateHeroUrl(publicId),
    product: generateProductUrl(publicId),
    srcset: generateResponsiveSrcset(publicId),
  };
};

/**
 * Batch upload images to Cloudinary (for initial setup)
 * Requires VITE_CLOUDINARY_API_SECRET to be set
 */
export const uploadImageToCloudinary = async (file, folder = 'sol-kin-furniture') => {
  const formData = new FormData();
  formData.append('file', file);
  formData.append('upload_preset', 'unsigned_upload'); // Create unsigned preset in Cloudinary
  formData.append('folder', folder);

  try {
    const response = await fetch(
      `https://api.cloudinary.com/v1_1/${CLOUD_NAME}/image/upload`,
      {
        method: 'POST',
        body: formData,
      }
    );

    const data = await response.json();
    return {
      publicId: data.public_id,
      url: data.secure_url,
      width: data.width,
      height: data.height,
    };
  } catch (error) {
    console.error('Error uploading to Cloudinary:', error);
    throw error;
  }
};

export default {
  generateCloudinaryUrl,
  generateResponsiveSrcset,
  generateThumbnail,
  generateHeroUrl,
  generateProductUrl,
  generateAllImageSizes,
  uploadImageToCloudinary,
};
