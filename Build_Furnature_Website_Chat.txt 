const sharp = require('sharp');
const fs = require('fs');
const path = require('path');

const sizes = [400, 800, 1200];
const qualities = { low: 60, medium: 75, high: 85 };

async function optimizeImages() {
  const photoDir = 'Project_References/Photos';
  const outputDir = 'public/images/optimized';
  
  const files = fs.readdirSync(photoDir).filter(f => f.endsWith('.jpg'));
  
  for (const file of files) {
    for (const size of sizes) {
      await sharp(path.join(photoDir, file))
        .resize(size, size * 0.75, { fit: 'cover' })
        .webp({ quality: qualities.high })
        .toFile(path.join(outputDir, `${file}-${size}w.webp`));
      
      // Also create JPG fallback
      await sharp(path.join(photoDir, file))
        .resize(size, size * 0.75, { fit: 'cover' })
        .jpeg({ quality: qualities.high })
        .toFile(path.join(outputDir, `${file}-${size}w.jpg`));
    }
  }
  
  console.log('✅ All images optimized');
}

